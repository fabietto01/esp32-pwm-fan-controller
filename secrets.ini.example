; ============================================================
;  WiFi credentials template.
;  Copy this file to secrets.ini and fill in your values.
;  secrets.ini is gitignored and must never be committed.
; ============================================================
[env]
build_flags =
    -D WIFI_SSID=\"YOUR_SSID\"
    -D WIFI_PASSWORD=\"YOUR_PASSWORD\"    ; Static IP — uncomment all three lines to use a fixed IP instead of DHCP
    ; -D STATIC_IP="192.168.1.100"
    ; -D STATIC_GATEWAY="192.168.1.1"
    ; -D STATIC_SUBNET="255.255.255.0"